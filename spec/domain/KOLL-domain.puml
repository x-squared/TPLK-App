@startuml
title TPL Domain - KOLL (Kolloquien)

hide methods
hide stereotypes
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

class Person
class Episode
class ColloqiumType
class ColloqiumTypeParticipant
class Colloqium
class ColloqiumParticipant
class ColloqiumSignatory
class ColloqiumAgenda
class TaskGroup

Colloqium : signatories (string)
Colloqium : completed (bool, one-way false -> true)

ColloqiumType "1" -- "0..*" ColloqiumTypeParticipant
Person "1" <-- "0..*" ColloqiumTypeParticipant : default participants

ColloqiumType "1" -- "0..*" Colloqium
Colloqium "1" -- "0..*" ColloqiumParticipant
Person "1" <-- "0..*" ColloqiumParticipant : participants
Colloqium "1" -- "0..*" ColloqiumSignatory
Person "1" <-- "0..*" ColloqiumSignatory : signatories

Colloqium "1" -- "0..*" ColloqiumAgenda
Episode "1" <-- "0..*" ColloqiumAgenda : references >
Person "1" <-- "0..*" ColloqiumAgenda : presented by >
TaskGroup "1" <-- "0..*" ColloqiumAgenda : optional task context

@enduml
